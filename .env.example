# PostgreSQL (used by docker compose; local dev defaults to SQLite)
POSTGRES_USER=cleaner
POSTGRES_PASSWORD=cleaner
POSTGRES_DB=cleaner
POSTGRES_PORT=5432

# Backend
# Local dev without Postgres: DATABASE_URL=sqlite:///./app.db
DATABASE_URL=postgresql+psycopg://cleaner:cleaner@localhost:5432/cleaner
STORAGE_DIR=./_storage
LOG_LEVEL=INFO

# Upload limit in megabytes (enforced while streaming to disk).
MAX_UPLOAD_MB=50

# Comma-separated list of allowed CORS origins. Never use "*" in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQL import connects to a caller-supplied database URL — an SSRF vector on
# hosted deployments. Keep disabled unless you trust every API caller.
ENABLE_SQL_IMPORT=false

# Frontend
VITE_API_BASE_URL=http://localhost:8000
